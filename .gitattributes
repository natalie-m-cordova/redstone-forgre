# ============================================
# Redstone Forge - Line Ending Rules
# ============================================

# Force LF for all text files (cross-platform safe)
* text=auto eol=lf

# Explicit overrides (documentation clarity)
*.json text eol=lf
*.md   text eol=lf
*.ts   text eol=lf
*.js   text eol=lf
*.tsx  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf