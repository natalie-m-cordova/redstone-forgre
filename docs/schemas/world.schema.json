{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://redstone-forge.local/schemas/world.schema.json",
  "title": "World",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "relativePath", "createdAt"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable world identifier (slug).",
      "pattern": "^[a-z0-9-]{3,64}$"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "relativePath": {
      "type": "string",
      "description": "Path relative to WORLDS_ROOT. Never absolute.",
      "pattern": "^(?!\\.?$)(?!\\./)(?!/)(?!.*\\.\\.)(?!.*:)[a-zA-Z0-9._/-]+$"

    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "lastPlayedAt": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "string",
      "maxLength": 500
    }
  }
}